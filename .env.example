# ==============================================================
# FortiEDR MCP Server configuration
# ==============================================================

# --- Required: FortiEDR Central Manager access ------------------
# A user with the Rest API role is required. The Admin role is not sufficient on its own.
# After creating the user, log in to the console once and rotate the password.
FORTIEDR_HOST=edr.your-company.com
FORTIEDR_USER=api_user
FORTIEDR_PASSWORD=change-me

# --- Multi-tenant (MSSP) --------------------------------------
# Default organization. Used when the organization parameter is omitted in a tool call.
# In MSSP environments we recommend leaving this empty and passing the org on every call —
# it prevents the "touched the wrong customer's device" mistake.
FORTIEDR_DEFAULT_ORG=

# --- Safety modes ----------------------------------------------
# READ_ONLY=true: only read-only tools are registered.
#   The safest mode. Enough for reporting, hunting, and triage.
FORTIEDR_READ_ONLY=true

# ENABLE_DESTRUCTIVE: only meaningful when READ_ONLY=false.
#   When true, isolate/unisolate/uninstall/remediate become available.
#   Enable only for senior-analyst deployments.
FORTIEDR_ENABLE_DESTRUCTIVE=false

# EXPOSE_RAW_API=true: registers all 146 auto-generated tool stubs.
#   Default is false — only the ~17 curated/composite tools are exposed,
#   which makes Claude's tool selection more reliable. Enable only if you
#   need raw access to every FortiEDR API endpoint from the model.
FORTIEDR_EXPOSE_RAW_API=false

# --- Connection settings --------------------------------------
# Set to false if you use a self-signed certificate
FORTIEDR_VERIFY_SSL=true

# --- Transport ------------------------------------------------
# stdio: Claude Desktop, Cursor, VS Code, Claude Code (default)
# http:  Remote deployment, Docker
FORTIEDR_TRANSPORT=stdio
FORTIEDR_HTTP_HOST=127.0.0.1
FORTIEDR_HTTP_PORT=3000

# --- Logging --------------------------------------------------
FORTIEDR_LOG_LEVEL=INFO
